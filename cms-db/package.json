{
  "name": "cms-db",
  "version": "1.0.0",
  "description": "内製CMSのD1スキーマ管理（migrations）とmicroCMSからのデータインポート",
  "private": true,
  "type": "module",
  "scripts": {
    "migrate:local": "wrangler d1 migrations apply maretol-cms --local",
    "migrate:remote": "wrangler d1 migrations apply maretol-cms --remote",
    "export": "tsx scripts/export_microcms.ts",
    "generate-sql:illust": "tsx scripts/generate_illust_sql.ts"
  },
  "devDependencies": {
    "tsx": "^4.20.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.105.0"
  }
}
